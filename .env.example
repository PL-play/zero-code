# OpenAI-compatible model id (required)
OPENAI_COMPAT_MODEL=

# OpenAI-compatible API base URL (required)
OPENAI_COMPAT_BASE_URL=

# OpenAI-compatible API key (required)
OPENAI_COMPAT_API_KEY=

CONTEXT_COMPACT_THRESHOLD=50000

# Stream render debounce (TUI)
# Flush stream text at least every N seconds (lower = smoother, higher = less flicker)
STREAM_FLUSH_MIN_INTERVAL_S=0.08
# Flush immediately when pending stream text reaches N chars
STREAM_FLUSH_MIN_CHARS=24

# Live panel behavior (TUI)
# Delay before hiding think panel after stream end
THINK_PANEL_HIDE_DELAY_S=1.8
# Delay before hiding tool panel after a no-tool round
TOOL_PANEL_HIDE_DELAY_S=2.2
# Tool panel title
TOOL_CHAIN_TITLE=Tool Execution Chain

# Chat input placeholder
CHAT_INPUT_PLACEHOLDER=Please enter your message and press Enter to send.

# Optional: custom skills directory.
# If unset or the directory does not exist, runtime falls back to: <agent_home>/.skills
# Relative paths are resolved against agent_home.
# ZERO_CODE_SKILLS_DIR=.skills

OPENAI_COMPAT_SUPPORTS_IMAGE_INPUT=true
OPENAI_COMPAT_SUPPORTS_PDF_INPUT_CHAT=true
OPENAI_COMPAT_SUPPORTS_PDF_INPUT_RESPONSES=true
OPENAI_COMPAT_SUPPORTS_DATA_URL=true

# Optional: register the generate_image tool only when both vars are set.
# Uses Qwen-Image via DashScope and downloads generated images into the workspace.
# DASHSCOPE_API_KEY=
# DASHSCOPE_IMAGE_MODEL=qwen-image-2.0-pro
# DASHSCOPE_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_IMAGE_DEFAULT_SIZE=1024*1024
# DASHSCOPE_IMAGE_OUTPUT_DIR=outputs/generated-images
# DASHSCOPE_IMAGE_PROMPT_EXTEND=true
# DASHSCOPE_IMAGE_WATERMARK=false
# DASHSCOPE_IMAGE_USE_PROXY=false

# Optional: register the edit_image tool only when both vars are set.
# Uses Qwen-Image edit via DashScope and downloads edited images into the workspace.
# DASHSCOPE_IMAGE_EDIT_MODEL=qwen-image-2.0-pro
# DASHSCOPE_IMAGE_EDIT_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_IMAGE_EDIT_DEFAULT_SIZE=1024*1024
# DASHSCOPE_IMAGE_EDIT_OUTPUT_DIR=outputs/edited-images

# Optional: register the web_search tool only when both SEARXNG_BASE_URL and SEARXNG_API_TOKEN are set.
# Uses SearXNG Private Gateway for web search.
# SEARXNG_BASE_URL=http://localhost:18123
# SEARXNG_API_TOKEN=
# SEARXNG_MAX_RESULTS=5
# SEARXNG_SNIPPET_MAX_LENGTH=240
# SEARXNG_TIMEOUT_S=30

# DASHSCOPE_IMAGE_EDIT_PROMPT_EXTEND=true
# DASHSCOPE_IMAGE_EDIT_WATERMARK=false
# DASHSCOPE_IMAGE_EDIT_USE_PROXY=false

# Provider examples
# MiniMax:  OPENAI_COMPAT_BASE_URL=https://api.minimaxi.com/v1
# GLM:      OPENAI_COMPAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Kimi:     OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
# DeepSeek: OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1

