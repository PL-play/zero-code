# OpenAI-compatible model id (required)
OPENAI_COMPAT_MODEL=

# OpenAI-compatible API base URL (required)
OPENAI_COMPAT_BASE_URL=

# OpenAI-compatible API key (required)
OPENAI_COMPAT_API_KEY=

CONTEXT_COMPACT_THRESHOLD=50000

# Stream render debounce (TUI)
# Flush stream text at least every N seconds (lower = smoother, higher = less flicker)
STREAM_FLUSH_MIN_INTERVAL_S=0.08
# Flush immediately when pending stream text reaches N chars
STREAM_FLUSH_MIN_CHARS=24

# Live panel behavior (TUI)
# Delay before hiding think panel after stream end
THINK_PANEL_HIDE_DELAY_S=1.8
# Delay before hiding tool panel after a no-tool round
TOOL_PANEL_HIDE_DELAY_S=2.2
# Tool panel title
TOOL_CHAIN_TITLE=Tool Execution Chain

# Provider examples
# MiniMax:  OPENAI_COMPAT_BASE_URL=https://api.minimaxi.com/v1
# GLM:      OPENAI_COMPAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Kimi:     OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
# DeepSeek: OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1

